function convertHTML(str) {
  const entities = {
    "&": "&amp;",
    "<": "&lt;",
    ">": "&gt;",
    '"': "&quot;",
    "'": "&apos;"
  };
  let result = "";
  for (let char of str) {
    if (entities[char]) {
      result += entities[char];
    } else {
      result += char;
    }
  }
  return result;
}
Object mapping(对象映射法转换为HTML）
